{
  "name": "storage-analyzer",
  "productName": "ניהול אחסון",
  "version": "1.2.1",
  "description": "אפליקציית ניתוח אחסון ל-Windows 11 — מאתרת מה תופס מקום בכוננים",
  "main": "main.js",
  "author": "Matan",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.matan.storage-analyzer",
    "productName": "ניהול אחסון",
    "files": [
      "main.js",
      "preload.js",
      "scanner-worker.js",
      "renderer/**/*",
      "build/icon.ico"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "ניהול אחסון",
      "artifactName": "disk-space-analyzer-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "disk-space-analyzer-portable-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
